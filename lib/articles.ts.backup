export function getArticlesForGame(
  gameSlug: string,
  category?: string
): Article[] {
  return articles.filter(
    (a) =>
      a.gameSlug === gameSlug &&
      (category ? a.category === category : true)
  );
}

export function getArticleBySlug(
  slug: string,
  gameSlug: string
): Article | undefined {
  return articles.find((a) => a.slug === slug && a.gameSlug === gameSlug);
}

export function getAllArticleSlugs(): { slug: string; gameSlug: string }[] {
  return articles.map((a) => ({ slug: a.slug, gameSlug: a.gameSlug }));
}

export const ARTICLE_CATEGORIES = ["builds", "bosses", "weapons", "walkthroughs"] as const;
